# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Supabase database. Leave empty to use local db.json while developing.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SECRET_KEY="your-server-only-secret-key"
# SUPABASE_SERVICE_ROLE_KEY is also supported if your Supabase dashboard uses that name.
SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
SUPABASE_JWKS_URL="https://your-project.supabase.co/auth/v1/.well-known/jwks.json"

# Admin login and session. These are checked on the server, not exposed in frontend JS.
ADMIN_PHONE="your-admin-phone"
ADMIN_PIN="your-strong-admin-pin"
ADMIN_SESSION_HOURS="8"

# Telegram notifications for new orders and consultation requests.
# Create a bot with @BotFather, message the bot once, then use getUpdates to find chat_id.
# After filling these values, restart the server and POST /api/telegram/test to test.
TELEGRAM_NOTIFY_ENABLED="false"
TELEGRAM_BOT_TOKEN="123456789:your-bot-token"
TELEGRAM_CHAT_ID="your-chat-id"
